	cd /home/runner/work/voronoi_dynamics/voronoi_dynamics/build_baseline && $(CMAKE_COMMAND) -S$(CMAKE_SOURCE_DIR) -B$(CMAKE_BINARY_DIR) --check-build-system CMakeFiles/Makefile.cmake 0
